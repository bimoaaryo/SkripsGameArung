  m_EditorClassIdentifier: 
  namaPedagang: Pedagang Eropa
  portraitSprite: {fileID: 21300000, guid: 95a0cdb8133588c488fda4640f9d3c7d, type: 3}
  dialogPedagang_ID: Pala dari Maluku? Kami beli, tapi harganya sudah kami tentukan
    100 gulden. Mau atau tidak, terserah kamu.
  dialogPedagang_EN: Nutmeg from Maluku? We'll buy it, but the price is already set
    100 gulden. Take it or leave it, your choice.
  ekspresiArungPanel: 1
  playerTag: Player
  modeNpcPembeliRempah: 0
  opsiA:
    labelOpsi_ID: Pala sudah terjual
    labelOpsi_EN: Nutmeg already sold out
    deskripsi_ID: 
    deskripsi_EN: 
    nilaiGulden: 0
    teksHasil: Pala habis terjual ke Pedagang Arab
    rempahDibutuhkan: 
    rempahHarusTerjual: Pala
    reaksiPedagang_ID: 
    reaksiPedagang_EN: 
  opsiB:
