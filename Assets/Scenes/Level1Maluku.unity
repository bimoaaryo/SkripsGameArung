  portraitSprite: {fileID: 21300000, guid: 626a7f8be60770f4588cb34790fccc6e, type: 3}
  dialogPedagang_ID: 'Saudagar muda! Aku tertarik dengan Pala yang kau bawa. Kubeli
    sekarang dengan harga yang baik: 200 gulden. Bagaimana, mau kau jual?'
  dialogPedagang_EN: 'Young merchant! I''m interested in the nutmeg you''re carrying.
    I''ll buy it now at a good price: 200 gulden. So, will you sell?'
  ekspresiArungPanel: 1
  playerTag: Player
  modeNpcPembeliRempah: 0
